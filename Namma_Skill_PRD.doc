        color: #0e5d43;
        font-size: 30px;
        margin-bottom: 8px;
      }
      h2 {
        border-bottom: 1px solid #dbe4dd;
        color: #10251d;
        font-size: 20px;
        margin-top: 28px;
        padding-bottom: 6px;
      }
      h3 {
        color: #167a57;
        font-size: 16px;
        margin-top: 18px;
      }
      p, li {
        font-size: 12.5px;
      }
      table {
        border-collapse: collapse;
        margin: 12px 0;
        width: 100%;
      }
      th, td {
        border: 1px solid #dbe4dd;
        font-size: 12.5px;
        padding: 9px;
        text-align: left;
        vertical-align: top;
      }
      th {
        background: #eef4f0;
        color: #10251d;
